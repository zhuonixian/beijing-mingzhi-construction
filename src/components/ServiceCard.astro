---
interface Props {
  name: string;
  category: string;
  description: string;
  slug: string;
  icon: string;
}

const { name, category, description, slug, icon } = Astro.props;

const iconMap: Record<string, string> = {
  'construction': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2 20h20M5 20V8l7-5 7 5v12M9 20v-6h6v6"/><rect x="9" y="10" width="2" height="2" rx="0.5"/><rect x="13" y="10" width="2" height="2" rx="0.5"/></svg>`,
  'workers': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>`,
  'tool': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>`,
  'design': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"/><path d="M13 13l6 6"/></svg>`,
  'clipboard': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 14l2 2 4-4"/></svg>`,
  'building': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21h18M3 7v14M21 7v14M6 11h4M6 15h4M14 11h4M14 15h4"/><path d="M6 7h12l-2-4H8L6 7z"/></svg>`,
  'crane': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2 20h20M6 20V4l8 4M14 8h6M20 8v6M20 14h-2v2"/><line x1="6" y1="20" x2="14" y2="12" stroke-dasharray="2 2"/></svg>`,
  'box': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12"/></svg>`,
};
---

<a href={`/services/${slug}/`} class="group block bg-stone-50 border-l-[3px] border-l-olive border border-stone-200 p-5 lg:p-6 hover:bg-white hover:border-l-olive-dark hover:shadow-sm transition-all duration-300 stripe-deco">
  <div class="flex items-start justify-between mb-4">
    <div class="w-9 h-9 flex items-center justify-center bg-olive/10 text-olive-dark rounded-sm group-hover:bg-olive group-hover:text-white transition-colors" set:html={iconMap[icon] || iconMap['construction']} />
    <svg class="w-3.5 h-3.5 text-stone-300 group-hover:text-olive group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/>
    </svg>
  </div>
  <span class="text-[10px] tracking-[0.2em] text-olive-muted uppercase font-semibold mb-1.5 block">{category}</span>
  <h3 class="text-base font-bold text-stone-800 mb-1.5 group-hover:text-olive-dark transition-colors">{name}</h3>
  <p class="text-xs text-stone-500 leading-relaxed">{description}</p>
</a>

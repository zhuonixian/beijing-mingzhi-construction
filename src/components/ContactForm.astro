---

---

<section class="bg-white border border-stone-200 p-6 lg:p-8">
  <div class="mb-6">
    <h2 class="text-lg font-bold text-stone-900 mb-1">在线留言</h2>
    <p class="text-xs text-stone-400">填写以下信息，我们将尽快与您联系</p>
  </div>

  <form
    x-data="{ submitting: false, success: false, error: '' }"
    @submit.prevent="
      submitting = true; error = ''; success = false;
      const form = $el;
      const data = {
        name: form.name.value,
        phone: form.phone.value,
        email: form.email.value,
        message: form.message.value
      };
      fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(r => r.json())
      .then(d => {
        submitting = false;
        if (d.ok) { success = true; form.reset(); }
        else { error = d.message || '提交失败，请稍后重试'; }
      })
      .catch(() => { submitting = false; error = '网络错误，请稍后重试'; });
    "
    class="space-y-5"
  >
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="name" class="block text-[10px] tracking-[0.15em] text-stone-400 mb-1.5">姓名 <span class="text-red-400">*</span></label>
        <input
          type="text" id="name" name="name" required
          maxlength="50"
          class="w-full px-3 py-2.5 border border-stone-200 text-sm text-stone-800 placeholder:text-stone-300 focus:border-olive focus:ring-0 transition-colors bg-stone-50"
          placeholder="请输入您的姓名"
        />
      </div>
      <div>
        <label for="phone" class="block text-[10px] tracking-[0.15em] text-stone-400 mb-1.5">电话</label>
        <input
          type="tel" id="phone" name="phone"
          pattern="[\d\s\-+()]{5,20}"
          class="w-full px-3 py-2.5 border border-stone-200 text-sm text-stone-800 placeholder:text-stone-300 focus:border-olive focus:ring-0 transition-colors bg-stone-50"
          placeholder="请输入您的电话号码"
        />
      </div>
    </div>

    <div>
      <label for="email" class="block text-[10px] tracking-[0.15em] text-stone-400 mb-1.5">邮箱</label>
      <input
        type="email" id="email" name="email"
        pattern="^\S+@\S+\.\S+$"
        class="w-full px-3 py-2.5 border border-stone-200 text-sm text-stone-800 placeholder:text-stone-300 focus:border-olive focus:ring-0 transition-colors bg-stone-50"
        placeholder="请输入您的邮箱地址"
      />
    </div>

    <div>
      <label for="message" class="block text-[10px] tracking-[0.15em] text-stone-400 mb-1.5">留言内容 <span class="text-red-400">*</span></label>
      <textarea
        id="message" name="message" required rows="4"
        maxlength="2000"
        class="w-full px-3 py-2.5 border border-stone-200 text-sm text-stone-800 placeholder:text-stone-300 focus:border-olive focus:ring-0 transition-colors bg-stone-50 resize-none"
        placeholder="请输入您的留言内容"
      ></textarea>
    </div>

    <div x-show="error" x-text="error" class="text-sm text-red-500"></div>
    <div x-show="success" class="text-sm text-olive-dark">留言提交成功，我们将尽快与您联系。</div>

    <div class="pt-2">
      <button
        type="submit"
        :disabled="submitting"
        class="group inline-flex items-center gap-2 px-7 py-2.5 bg-olive text-white text-sm tracking-wider font-bold hover:bg-olive-dark transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
      >
        <span x-show="!submitting">提交留言</span>
        <span x-show="submitting">提交中...</span>
      </button>
    </div>
  </form>
</section>

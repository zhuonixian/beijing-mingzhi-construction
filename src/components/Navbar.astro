---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: '首页' },
  { href: '/about/', label: '关于我们' },
  { href: '/services/', label: '服务项目' },
  { href: '/news/', label: '新闻动态' },
  { href: '/contact/', label: '联系我们' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header
  x-data="{ scrolled: false, mobileOpen: false }"
  x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 40 })"
  :class="scrolled ? 'bg-stone-900/95 backdrop-blur-sm' : 'bg-stone-900'"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14 lg:h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 shrink-0 group">
        <svg class="h-7 w-7 text-brass" viewBox="0 0 32 32" fill="none">
          <rect x="4" y="10" width="24" height="16" stroke="currentColor" stroke-width="1.5" fill="none"/>
          <path d="M16 5L4 10h24L16 5z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
          <rect x="10" y="14" width="4" height="5" stroke="currentColor" stroke-width="0.75" fill="none"/>
          <rect x="18" y="14" width="4" height="5" stroke="currentColor" stroke-width="0.75" fill="none"/>
          <line x1="16" y1="10" x2="16" y2="26" stroke="currentColor" stroke-width="0.5"/>
        </svg>
        <div>
          <span class="text-sm font-bold tracking-widest text-stone-100 group-hover:text-brass transition-colors">铭挚建筑</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-8">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'text-xs tracking-[0.15em] transition-colors duration-300 relative py-1',
              isActive(item.href)
                ? 'text-brass font-bold'
                : 'text-stone-400 hover:text-stone-100'
            ]}
          >
            {item.label}
            {isActive(item.href) && (
              <span class="absolute bottom-0 left-0 right-0 h-[2px] bg-olive"></span>
            )}
          </a>
        ))}
      </div>

      <!-- Mobile toggle -->
      <button
        @click="mobileOpen = !mobileOpen"
        class="lg:hidden p-2 text-stone-400 hover:text-brass transition-colors"
        aria-label="菜单"
      >
        <svg x-show="!mobileOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" d="M3 6h18M3 12h18M3 18h18"/>
        </svg>
        <svg x-show="mobileOpen" x-cloak class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu - collapsed by default -->
    <div
      x-show="mobileOpen"
      x-cloak
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-2"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 -translate-y-2"
      class="lg:hidden"
    >
      <div class="border-t border-stone-700/50 py-3 space-y-0.5">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'block px-3 py-2.5 text-sm tracking-wider transition-colors rounded',
              isActive(item.href)
                ? 'text-brass font-semibold bg-stone-800'
                : 'text-stone-400 hover:text-stone-100 hover:bg-stone-800/50'
            ]}
            @click="mobileOpen = false"
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- Bottom olive accent line -->
  <div class="h-[2px] bg-gradient-to-r from-transparent via-olive/60 to-transparent"></div>
</header>

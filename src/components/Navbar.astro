---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: '首页' },
  { href: '/about/', label: '关于我们' },
  { href: '/services/', label: '服务项目' },
  { href: '/news/', label: '新闻动态' },
  { href: '/contact/', label: '联系我们' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header
  x-data="{ scrolled: false, mobileOpen: false }"
  x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 40 })"
  :class="scrolled ? 'bg-stone-50/95 backdrop-blur-sm shadow-[0_1px_0_0_#E7E5E4]' : 'bg-transparent'"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <nav class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href="/" class="flex items-center gap-3 shrink-0 group">
        <svg class="h-8 w-8 text-primary" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="8" width="28" height="22" stroke="currentColor" stroke-width="1.5" fill="none"/>
          <path d="M16 2L2 8h28L16 2z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
          <rect x="8" y="14" width="6" height="8" stroke="currentColor" stroke-width="1" fill="none"/>
          <rect x="18" y="14" width="6" height="8" stroke="currentColor" stroke-width="1" fill="none"/>
          <line x1="16" y1="14" x2="16" y2="30" stroke="currentColor" stroke-width="1"/>
        </svg>
        <div class="hidden sm:block">
          <span class="text-base font-semibold tracking-wide text-stone-800 group-hover:text-primary transition-colors">铭挚建筑</span>
          <span class="hidden lg:inline ml-2 text-xs text-stone-400 tracking-widest uppercase">MINGZHI</span>
        </div>
      </a>

      <div class="hidden lg:flex items-center gap-10">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'text-[13px] tracking-wider transition-colors duration-300',
              isActive(item.href)
                ? 'text-primary font-semibold'
                : 'text-stone-500 hover:text-stone-800'
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>

      <button
        @click="mobileOpen = !mobileOpen"
        class="lg:hidden p-2 text-stone-500 hover:text-stone-800 transition-colors"
        aria-label="菜单"
      >
        <svg x-show="!mobileOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg x-show="mobileOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div
      x-show="mobileOpen"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-1"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 -translate-y-1"
      class="lg:hidden border-t border-stone-200 py-4 space-y-1"
    >
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={[
            'block px-2 py-3 text-sm tracking-wider transition-colors',
            isActive(item.href)
              ? 'text-primary font-semibold'
              : 'text-stone-500 hover:text-stone-800'
          ]}
          @click="mobileOpen = false"
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

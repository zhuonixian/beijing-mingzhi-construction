---
interface Props {
  title: string;
  date: string;
  excerpt: string;
  slug: string;
  category: string;
}

const { title, date, excerpt, slug, category } = Astro.props;
---

<a href={`/news/${slug}/`} class="group block bg-stone-50 border border-stone-200 p-5 lg:p-6 hover:bg-white hover:shadow-sm transition-all duration-300">
  <div class="flex items-center gap-2 mb-3">
    <span class="text-[10px] tracking-[0.15em] text-olive font-bold uppercase">{category}</span>
    <span class="w-1 h-1 rounded-full bg-stone-300"></span>
    <time class="text-[10px] tracking-wider text-stone-400 font-mono">{date}</time>
  </div>
  <h3 class="text-sm font-bold text-stone-800 mb-2 group-hover:text-olive-dark transition-colors leading-snug">{title}</h3>
  <p class="text-xs text-stone-500 leading-relaxed line-clamp-3 mb-4">{excerpt}</p>
  <span class="inline-flex items-center gap-1 text-[11px] tracking-wider text-olive font-semibold group-hover:text-olive-dark transition-colors">
    阅读全文
    <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
  </span>
</a>

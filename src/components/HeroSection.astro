---

---

<section class="relative min-h-[85vh] flex items-center bg-stone-50 overflow-hidden">
  <!-- Architectural line decoration -->
  <svg class="absolute inset-0 w-full h-full opacity-[0.06]" viewBox="0 0 1440 900" fill="none" preserveAspectRatio="xMidYMid slice">
    <!-- Grid lines -->
    <line x1="200" y1="0" x2="200" y2="900" stroke="#5C4033" stroke-width="0.5"/>
    <line x1="400" y1="0" x2="400" y2="900" stroke="#5C4033" stroke-width="0.5"/>
    <line x1="600" y1="0" x2="600" y2="900" stroke="#5C4033" stroke-width="0.5"/>
    <line x1="800" y1="0" x2="800" y2="900" stroke="#5C4033" stroke-width="0.5"/>
    <line x1="1000" y1="0" x2="1000" y2="900" stroke="#5C4033" stroke-width="0.5"/>
    <line x1="1200" y1="0" x2="1200" y2="900" stroke="#5C4033" stroke-width="0.5"/>
    <line x1="0" y1="150" x2="1440" y2="150" stroke="#5C4033" stroke-width="0.5"/>
    <line x1="0" y1="300" x2="1440" y2="300" stroke="#5C4033" stroke-width="0.5"/>
    <line x1="0" y1="450" x2="1440" y2="450" stroke="#5C4033" stroke-width="0.5"/>
    <line x1="0" y1="600" x2="1440" y2="600" stroke="#5C4033" stroke-width="0.5"/>
    <line x1="0" y1="750" x2="1440" y2="750" stroke="#5C4033" stroke-width="0.5"/>
    <!-- Building outline -->
    <rect x="120" y="200" width="280" height="500" stroke="#5C4033" stroke-width="1"/>
    <rect x="160" y="260" width="60" height="80" stroke="#5C4033" stroke-width="0.5"/>
    <rect x="260" y="260" width="60" height="80" stroke="#5C4033" stroke-width="0.5"/>
    <rect x="160" y="400" width="60" height="80" stroke="#5C4033" stroke-width="0.5"/>
    <rect x="260" y="400" width="60" height="80" stroke="#5C4033" stroke-width="0.5"/>
    <line x1="260" y1="200" x2="260" y2="700" stroke="#5C4033" stroke-width="0.5"/>
    <polygon points="120,200 260,100 400,200" stroke="#5C4033" stroke-width="1" fill="none"/>
    <!-- Crane -->
    <line x1="900" y1="700" x2="900" y2="100" stroke="#5C4033" stroke-width="1"/>
    <line x1="900" y1="100" x2="1100" y2="100" stroke="#5C4033" stroke-width="1"/>
    <line x1="900" y1="100" x2="800" y2="150" stroke="#5C4033" stroke-width="0.5"/>
    <line x1="1100" y1="100" x2="1100" y2="200" stroke="#5C4033" stroke-width="0.5" stroke-dasharray="4 4"/>
    <!-- Dimension lines -->
    <line x1="120" y1="720" x2="400" y2="720" stroke="#5C4033" stroke-width="0.5"/>
    <line x1="120" y1="715" x2="120" y2="725" stroke="#5C4033" stroke-width="0.5"/>
    <line x1="400" y1="715" x2="400" y2="725" stroke="#5C4033" stroke-width="0.5"/>
  </svg>

  <!-- Left accent line -->
  <div class="absolute left-8 lg:left-16 top-1/2 -translate-y-1/2 hidden md:flex flex-col items-center gap-4">
    <div class="w-px h-20 bg-stone-300"></div>
    <span class="text-[10px] tracking-[0.3em] text-stone-400 writing-vertical" style="writing-mode: vertical-rl;">MINGZHI CONSTRUCTION</span>
    <div class="w-px h-20 bg-stone-300"></div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-8 w-full">
    <div class="max-w-2xl">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-8 h-px bg-accent"></div>
        <span class="text-xs tracking-[0.3em] text-stone-400 uppercase">Est. 2024 Beijing</span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-stone-900 leading-[1.15] mb-6 tracking-tight">
        以匠心<br/>筑品质
      </h1>

      <p class="text-base sm:text-lg text-stone-500 leading-relaxed mb-10 max-w-lg">
        北京铭挚建筑工程有限公司，专注建设工程施工与工程管理服务，以专业的技术能力和严谨的管理体系，为客户提供安全、高效的建筑解决方案。
      </p>

      <div class="flex items-center gap-6">
        <a href="/services/" class="group inline-flex items-center gap-2 text-sm tracking-wider text-primary font-semibold hover:text-accent transition-colors">
          了解服务
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/>
          </svg>
        </a>
        <span class="text-stone-300">|</span>
        <a href="/contact/" class="text-sm tracking-wider text-stone-400 hover:text-primary transition-colors">
          联系我们
        </a>
      </div>
    </div>
  </div>

  <!-- Right side: large decorative number -->
  <div class="absolute right-8 lg:right-16 bottom-16 text-stone-200/60 hidden lg:block select-none pointer-events-none">
    <span class="text-[200px] font-bold leading-none tracking-tighter">01</span>
  </div>
</section>

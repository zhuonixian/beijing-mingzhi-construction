---

---

<section class="relative min-h-[90vh] lg:min-h-screen flex items-center bg-stone-900 overflow-hidden">
  <!-- Background: blueprint grid -->
  <svg class="absolute inset-0 w-full h-full opacity-[0.04]" viewBox="0 0 1440 900" fill="none" preserveAspectRatio="xMidYMid slice">
    <defs>
      <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
        <path d="M 60 0 L 0 0 0 60" fill="none" stroke="#C4A35A" stroke-width="0.5"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#grid)"/>
    <!-- Building silhouette -->
    <rect x="950" y="250" width="200" height="400" stroke="#C4A35A" stroke-width="0.8" fill="none"/>
    <rect x="1160" y="350" width="140" height="300" stroke="#C4A35A" stroke-width="0.8" fill="none"/>
    <rect x="990" y="290" width="40" height="50" stroke="#C4A35A" stroke-width="0.4" fill="none"/>
    <rect x="1070" y="290" width="40" height="50" stroke="#C4A35A" stroke-width="0.4" fill="none"/>
    <rect x="990" y="400" width="40" height="50" stroke="#C4A35A" stroke-width="0.4" fill="none"/>
    <rect x="1070" y="400" width="40" height="50" stroke="#C4A35A" stroke-width="0.4" fill="none"/>
    <rect x="990" y="510" width="40" height="50" stroke="#C4A35A" stroke-width="0.4" fill="none"/>
    <rect x="1070" y="510" width="40" height="50" stroke="#C4A35A" stroke-width="0.4" fill="none"/>
    <rect x="1200" y="390" width="30" height="40" stroke="#C4A35A" stroke-width="0.4" fill="none"/>
    <rect x="1240" y="390" width="30" height="40" stroke="#C4A35A" stroke-width="0.4" fill="none"/>
    <polygon points="950,250 1050,160 1150,250" stroke="#C4A35A" stroke-width="0.8" fill="none"/>
  </svg>

  <!-- Diagonal stripe texture overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background: repeating-linear-gradient(-45deg, transparent, transparent 3px, #C4A35A 3px, #C4A35A 4px);"></div>

  <!-- Olive gradient bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-olive-dark via-olive to-olive-dark"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-20 lg:py-0">
    <div class="max-w-2xl">
      <!-- Badge -->
      <div class="badge mb-8">
        <svg class="w-3.5 h-3.5 text-olive-muted" fill="currentColor" viewBox="0 0 20 20"><polygon points="10,1 12.5,7 19,7.5 14,12 15.5,19 10,15.5 4.5,19 6,12 1,7.5 7.5,7"/></svg>
        <span>Beijing Mingzhi Construction · Est. 2024</span>
      </div>

      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-stone-100 leading-[1.1] mb-6 tracking-tight">
        以匠心<br/>
        <span class="text-brass">筑品质</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-base sm:text-lg text-stone-400 leading-relaxed mb-10 max-w-lg">
        北京铭挚建筑工程有限公司，专注建设工程施工与工程管理服务，以专业的技术能力和严谨的管理体系，为客户提供安全、高效的建筑解决方案。
      </p>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <a href="/services/" class="group inline-flex items-center gap-2 px-7 py-3 bg-olive text-stone-100 text-sm tracking-wider font-bold hover:bg-olive-dark transition-colors">
          了解服务
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
        </a>
        <a href="/contact/" class="inline-flex items-center gap-2 px-7 py-3 border border-stone-600 text-stone-400 text-sm tracking-wider font-medium hover:border-brass hover:text-brass transition-colors">
          联系我们
        </a>
      </div>

      <!-- Quick stats bar -->
      <div class="mt-14 pt-8 border-t border-stone-700/50 grid grid-cols-3 gap-6 max-w-md">
        <div>
          <div class="text-2xl font-bold text-brass tracking-tight">800<span class="text-sm font-normal text-stone-500 ml-0.5">万</span></div>
          <div class="text-[10px] tracking-widest text-stone-500 mt-1 uppercase">注册资本</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brass tracking-tight">10<span class="text-sm font-normal text-stone-500 ml-0.5">+</span></div>
          <div class="text-[10px] tracking-widest text-stone-500 mt-1 uppercase">业务范围</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brass tracking-tight">100<span class="text-sm font-normal text-stone-500 ml-0.5">%</span></div>
          <div class="text-[10px] tracking-widest text-stone-500 mt-1 uppercase">品质承诺</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Right side: large number + vertical text -->
  <div class="absolute right-6 lg:right-16 bottom-20 lg:bottom-24 hidden sm:flex flex-col items-end gap-4">
    <span class="text-stone-700 text-[160px] lg:text-[200px] font-bold leading-none tracking-tighter select-none pointer-events-none">01</span>
  </div>
</section>

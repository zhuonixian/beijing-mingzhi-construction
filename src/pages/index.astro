---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import NewsCard from '@/components/NewsCard.astro';
import { services } from '@/data/services';
import { news } from '@/data/news';

const featuredServices = services.slice(0, 6);
const latestNews = news.slice(0, 3);
---

<BaseLayout title="首页">
  <HeroSection />

  <!-- Section divider -->
  <div class="section-divider"></div>

  <!-- 服务项目 -->
  <section class="py-16 lg:py-24 bg-stone-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="badge mb-5">
        <svg class="w-3 h-3 text-olive-muted" fill="currentColor" viewBox="0 0 20 20"><polygon points="10,1 12.5,7 19,7.5 14,12 15.5,19 10,15.5 4.5,19 6,12 1,7.5 7.5,7"/></svg>
        <span>Our Services</span>
      </div>
      <div class="flex items-end justify-between mb-10">
        <h2 class="text-2xl lg:text-3xl font-bold text-stone-900 tracking-tight">服务项目</h2>
        <a href="/services/" class="hidden sm:flex items-center gap-1.5 text-xs tracking-wider text-olive font-semibold hover:text-olive-dark transition-colors">
          查看全部
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featuredServices.map(service => (
          <ServiceCard
            name={service.name}
            category={service.category}
            description={service.description}
            slug={service.slug}
            icon={service.icon}
          />
        ))}
      </div>
      <div class="mt-6 text-center sm:hidden">
        <a href="/services/" class="inline-flex items-center gap-1.5 text-xs tracking-wider text-olive font-semibold">
          查看全部服务 →
        </a>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- 关于我们 - 军旅风格 -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">
        <div class="lg:col-span-5">
          <div class="badge mb-5">
            <svg class="w-3 h-3 text-olive-muted" fill="currentColor" viewBox="0 0 20 20"><polygon points="10,1 12.5,7 19,7.5 14,12 15.5,19 10,15.5 4.5,19 6,12 1,7.5 7.5,7"/></svg>
            <span>About Us</span>
          </div>
          <h2 class="text-2xl lg:text-3xl font-bold text-stone-900 tracking-tight mb-6">关于铭挚建筑</h2>
          <p class="text-stone-600 leading-relaxed mb-4 text-sm lg:text-base">
            北京铭挚建筑工程有限公司成立于2024年，注册资本800万元，是一家专注于建设工程施工及相关服务的综合性建筑企业。
          </p>
          <p class="text-stone-500 leading-relaxed mb-8 text-sm lg:text-base">
            承载建筑使命，践行工匠精神。公司经营范围涵盖建设工程施工、建筑劳务分包、专业设计服务、工程管理等核心领域。
          </p>
          <a href="/about/" class="group inline-flex items-center gap-2 text-sm tracking-wider text-olive font-bold hover:text-olive-dark transition-colors">
            了解更多
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
          </a>
        </div>

        <!-- 特色网格 - 军旅徽章风格 -->
        <div class="lg:col-span-7">
          <div class="grid grid-cols-2 gap-px bg-stone-200 border border-stone-200">
            <div class="bg-white p-6 sm:p-8 group">
              <div class="w-9 h-9 flex items-center justify-center bg-olive/10 rounded-sm mb-3 group-hover:bg-olive group-hover:text-white text-olive-dark transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              </div>
              <h3 class="text-sm font-bold text-stone-800 mb-1">资质齐全</h3>
              <p class="text-xs text-stone-400 leading-relaxed">依法取得各项经营资质，合规经营</p>
            </div>
            <div class="bg-white p-6 sm:p-8 group">
              <div class="w-9 h-9 flex items-center justify-center bg-olive/10 rounded-sm mb-3 group-hover:bg-olive group-hover:text-white text-olive-dark transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <h3 class="text-sm font-bold text-stone-800 mb-1">专业团队</h3>
              <p class="text-xs text-stone-400 leading-relaxed">经验丰富的施工队伍和管理人才</p>
            </div>
            <div class="bg-white p-6 sm:p-8 group">
              <div class="w-9 h-9 flex items-center justify-center bg-olive/10 rounded-sm mb-3 group-hover:bg-olive group-hover:text-white text-olive-dark transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <h3 class="text-sm font-bold text-stone-800 mb-1">高效执行</h3>
              <p class="text-xs text-stone-400 leading-relaxed">雷厉风行，高效推进每个项目</p>
            </div>
            <div class="bg-white p-6 sm:p-8 group">
              <div class="w-9 h-9 flex items-center justify-center bg-olive/10 rounded-sm mb-3 group-hover:bg-olive group-hover:text-white text-olive-dark transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
              </div>
              <h3 class="text-sm font-bold text-stone-800 mb-1">品质保障</h3>
              <p class="text-xs text-stone-400 leading-relaxed">严格标准，确保工程质量达标</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- 新闻动态 -->
  <section class="py-16 lg:py-24 bg-stone-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="badge mb-5">
        <svg class="w-3 h-3 text-olive-muted" fill="currentColor" viewBox="0 0 20 20"><polygon points="10,1 12.5,7 19,7.5 14,12 15.5,19 10,15.5 4.5,19 6,12 1,7.5 7.5,7"/></svg>
        <span>News</span>
      </div>
      <div class="flex items-end justify-between mb-10">
        <h2 class="text-2xl lg:text-3xl font-bold text-stone-900 tracking-tight">新闻动态</h2>
        <a href="/news/" class="hidden sm:flex items-center gap-1.5 text-xs tracking-wider text-olive font-semibold hover:text-olive-dark transition-colors">
          查看全部
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {latestNews.map(post => (
          <NewsCard
            title={post.title}
            date={post.date}
            excerpt={post.excerpt}
            slug={post.slug}
            category={post.category}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-20 bg-stone-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background: repeating-linear-gradient(-45deg, transparent, transparent 3px, #C4A35A 3px, #C4A35A 4px);"></div>
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center relative z-10">
      <div class="flex justify-center mb-6">
        <svg class="w-6 h-6 text-brass" fill="currentColor" viewBox="0 0 20 20"><polygon points="10,1 12.5,7 19,7.5 14,12 15.5,19 10,15.5 4.5,19 6,12 1,7.5 7.5,7"/></svg>
      </div>
      <h2 class="text-2xl lg:text-3xl font-bold text-stone-100 tracking-tight mb-3">需要建筑工程服务？</h2>
      <p class="text-stone-400 text-sm mb-8">欢迎联系我们，获取专业的建筑解决方案</p>
      <a href="/contact/" class="group inline-flex items-center gap-2 px-8 py-3 bg-olive text-stone-100 text-sm tracking-wider font-bold hover:bg-olive-dark transition-colors">
        立即咨询
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>

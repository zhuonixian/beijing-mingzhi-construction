---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import StatsSection from '@/components/StatsSection.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import NewsCard from '@/components/NewsCard.astro';
import { services } from '@/data/services';
import { news } from '@/data/news';

const featuredServices = services.slice(0, 6);
const latestNews = news.slice(0, 3);
---

<BaseLayout title="首页">
  <HeroSection />

  <StatsSection />

  <!-- 服务项目 -->
  <section class="py-20 lg:py-28 bg-stone-50">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-6 h-px bg-accent"></div>
        <span class="text-[10px] tracking-[0.3em] text-stone-400 uppercase">Our Services</span>
      </div>
      <div class="flex items-end justify-between mb-12">
        <h2 class="text-2xl lg:text-3xl font-bold text-stone-900 tracking-tight">服务项目</h2>
        <a href="/services/" class="hidden sm:flex items-center gap-1.5 text-xs tracking-wider text-stone-400 hover:text-primary transition-colors">
          查看全部
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {featuredServices.map(service => (
          <ServiceCard
            name={service.name}
            category={service.category}
            description={service.description}
            slug={service.slug}
            icon={service.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- 公司简介 -->
  <section class="py-20 lg:py-28 bg-white border-y border-stone-200">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-5">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-6 h-px bg-accent"></div>
            <span class="text-[10px] tracking-[0.3em] text-stone-400 uppercase">About Us</span>
          </div>
          <h2 class="text-2xl lg:text-3xl font-bold text-stone-900 tracking-tight mb-6">关于铭挚建筑</h2>
          <p class="text-stone-500 leading-relaxed mb-4">
            北京铭挚建筑工程有限公司成立于2024年，注册资本800万元，是一家专注于建设工程施工及相关服务的综合性建筑企业。
          </p>
          <p class="text-stone-500 leading-relaxed mb-8">
            公司经营范围涵盖建设工程施工、建筑劳务分包、专业设计服务、工程管理等核心领域，秉承"以匠心筑品质、以诚信铸未来"的理念。
          </p>
          <a href="/about/" class="group inline-flex items-center gap-2 text-sm tracking-wider text-primary font-semibold hover:text-accent transition-colors">
            了解更多
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
          </a>
        </div>

        <div class="lg:col-span-7">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-stone-200 border border-stone-200">
            <div class="bg-white p-8 group">
              <svg class="w-8 h-8 text-stone-300 group-hover:text-primary transition-colors mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
              <h3 class="font-semibold text-stone-800 mb-1.5">资质齐全</h3>
              <p class="text-sm text-stone-400 leading-relaxed">依法取得各项经营资质，合规经营</p>
            </div>
            <div class="bg-white p-8 group">
              <svg class="w-8 h-8 text-stone-300 group-hover:text-primary transition-colors mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <h3 class="font-semibold text-stone-800 mb-1.5">专业团队</h3>
              <p class="text-sm text-stone-400 leading-relaxed">经验丰富的施工队伍和管理人才</p>
            </div>
            <div class="bg-white p-8 group">
              <svg class="w-8 h-8 text-stone-300 group-hover:text-primary transition-colors mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
              <h3 class="font-semibold text-stone-800 mb-1.5">高效响应</h3>
              <p class="text-sm text-stone-400 leading-relaxed">快速响应客户需求，高效推进项目</p>
            </div>
            <div class="bg-white p-8 group">
              <svg class="w-8 h-8 text-stone-300 group-hover:text-primary transition-colors mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
              </svg>
              <h3 class="font-semibold text-stone-800 mb-1.5">品质保障</h3>
              <p class="text-sm text-stone-400 leading-relaxed">严格执行国家标准，确保工程质量</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 新闻动态 -->
  <section class="py-20 lg:py-28 bg-stone-50">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-6 h-px bg-accent"></div>
        <span class="text-[10px] tracking-[0.3em] text-stone-400 uppercase">News</span>
      </div>
      <div class="flex items-end justify-between mb-12">
        <h2 class="text-2xl lg:text-3xl font-bold text-stone-900 tracking-tight">新闻动态</h2>
        <a href="/news/" class="hidden sm:flex items-center gap-1.5 text-xs tracking-wider text-stone-400 hover:text-primary transition-colors">
          查看全部
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {latestNews.map(post => (
          <NewsCard
            title={post.title}
            date={post.date}
            excerpt={post.excerpt}
            slug={post.slug}
            category={post.category}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 lg:py-28 bg-white border-t border-stone-200">
    <div class="max-w-2xl mx-auto px-6 lg:px-8 text-center">
      <h2 class="text-2xl lg:text-3xl font-bold text-stone-900 tracking-tight mb-4">需要建筑工程服务？</h2>
      <p class="text-stone-500 mb-8">欢迎联系我们，获取专业的建筑解决方案</p>
      <a href="/contact/" class="group inline-flex items-center gap-2 px-8 py-3 border border-stone-800 text-stone-800 text-sm tracking-wider font-semibold hover:bg-stone-800 hover:text-white transition-all duration-300">
        立即咨询
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>

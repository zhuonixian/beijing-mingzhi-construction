---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageBanner from '@/components/PageBanner.astro';
---

<BaseLayout title="关于我们">
  <PageBanner title="关于我们" description="了解北京铭挚建筑工程有限公司" />

  <!-- 公司介绍 -->
  <section class="py-16 lg:py-24 bg-white border-b border-stone-200">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <p class="text-lg text-stone-600 leading-relaxed mb-6">
        北京铭挚建筑工程有限公司成立于2024年12月31日，注册资本800万元人民币，是一家经北京市门头沟区市场监督管理局批准设立的综合性建筑企业。统一社会信用代码为 91110109MAE8XY2PXA。
      </p>
      <p class="text-stone-500 leading-relaxed mb-4">
        公司经营范围涵盖建设工程施工、建筑劳务分包、施工专业作业、房地产开发经营等许可项目，以及专业设计服务、工程管理服务、物业管理、工业工程设计服务、技术服务与开发等一般项目，形成了以工程施工为核心、多业务协同发展的经营格局。
      </p>
      <p class="text-stone-500 leading-relaxed">
        铭挚建筑秉承"以匠心筑品质、以诚信铸未来"的企业理念，坚持安全第一、质量至上的原则，致力于为客户提供安全、高效、优质的建筑解决方案。
      </p>
    </div>
  </section>

  <!-- 企业理念 -->
  <section class="py-16 lg:py-24 bg-stone-50">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-6 h-px bg-accent"></div>
        <span class="text-[10px] tracking-[0.3em] text-stone-400 uppercase">Philosophy</span>
      </div>
      <h2 class="text-2xl lg:text-3xl font-bold text-stone-900 tracking-tight mb-12">企业理念</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-stone-200 border border-stone-200">
        <div class="bg-white p-10 text-center">
          <svg class="w-10 h-10 text-accent mx-auto mb-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
          </svg>
          <h3 class="text-lg font-semibold text-stone-800 mb-2">匠心筑品质</h3>
          <p class="text-sm text-stone-400 leading-relaxed">以工匠精神对待每一个工程细节，追求精益求精的施工品质。</p>
        </div>
        <div class="bg-white p-10 text-center">
          <svg class="w-10 h-10 text-accent mx-auto mb-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
          <h3 class="text-lg font-semibold text-stone-800 mb-2">诚信铸未来</h3>
          <p class="text-sm text-stone-400 leading-relaxed">以诚实守信为立业之本，对客户负责、对工程负责、对社会负责。</p>
        </div>
        <div class="bg-white p-10 text-center">
          <svg class="w-10 h-10 text-accent mx-auto mb-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          <h3 class="text-lg font-semibold text-stone-800 mb-2">安全第一</h3>
          <p class="text-sm text-stone-400 leading-relaxed">将安全生产放在首位，建立健全安全管理体系，确保施工安全。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 工商信息 -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-6 h-px bg-accent"></div>
        <span class="text-[10px] tracking-[0.3em] text-stone-400 uppercase">Registration</span>
      </div>
      <h2 class="text-2xl lg:text-3xl font-bold text-stone-900 tracking-tight mb-10">企业信息</h2>
      <div class="border border-stone-200 divide-y divide-stone-200">
        <div class="grid grid-cols-3 px-6 py-4 text-sm">
          <span class="text-stone-400">企业名称</span>
          <span class="col-span-2 text-stone-700">北京铭挚建筑工程有限公司</span>
        </div>
        <div class="grid grid-cols-3 px-6 py-4 text-sm">
          <span class="text-stone-400">统一社会信用代码</span>
          <span class="col-span-2 text-stone-700 font-mono text-xs tracking-wider">91110109MAE8XY2PXA</span>
        </div>
        <div class="grid grid-cols-3 px-6 py-4 text-sm">
          <span class="text-stone-400">企业类型</span>
          <span class="col-span-2 text-stone-700">有限责任公司（自然人投资或控股）</span>
        </div>
        <div class="grid grid-cols-3 px-6 py-4 text-sm">
          <span class="text-stone-400">法定代表人</span>
          <span class="col-span-2 text-stone-700">谢博策</span>
        </div>
        <div class="grid grid-cols-3 px-6 py-4 text-sm">
          <span class="text-stone-400">注册资本</span>
          <span class="col-span-2 text-stone-700">800万元人民币</span>
        </div>
        <div class="grid grid-cols-3 px-6 py-4 text-sm">
          <span class="text-stone-400">成立日期</span>
          <span class="col-span-2 text-stone-700">2024年12月31日</span>
        </div>
        <div class="grid grid-cols-3 px-6 py-4 text-sm">
          <span class="text-stone-400">营业期限</span>
          <span class="col-span-2 text-stone-700">2024年12月31日 至 无固定期限</span>
        </div>
        <div class="grid grid-cols-3 px-6 py-4 text-sm">
          <span class="text-stone-400">登记机关</span>
          <span class="col-span-2 text-stone-700">北京市门头沟区市场监督管理局</span>
        </div>
        <div class="grid grid-cols-3 px-6 py-4 text-sm">
          <span class="text-stone-400">企业地址</span>
          <span class="col-span-2 text-stone-700">北京市门头沟区中门寺街69号33幢6349号（集群注册）</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

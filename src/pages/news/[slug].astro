---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageBanner from '@/components/PageBanner.astro';
import { getStaticPaths as getPaths } from '@/data/news';
import type { NewsPost } from '@/data/news';

export function getStaticPaths() {
  return getPaths();
}

const { post } = Astro.props as { post: NewsPost };
---

<BaseLayout title={post.title}>
  <PageBanner title="新闻动态" description={post.category} />

  <div class="section-divider"></div>

  <article class="py-14 lg:py-20 bg-stone-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 mb-5">
        <span class="text-[10px] tracking-[0.15em] text-olive font-bold uppercase">{post.category}</span>
        <span class="w-1 h-1 rounded-full bg-stone-300"></span>
        <time class="text-[10px] tracking-wider text-stone-400 font-mono">{post.date}</time>
      </div>
      <h1 class="text-2xl lg:text-3xl font-bold text-stone-900 tracking-tight mb-8">{post.title}</h1>

      <div class="text-stone-600 text-sm lg:text-base leading-relaxed space-y-4" set:html={post.content} />

      <div class="mt-10 pt-6 border-t border-stone-200">
        <a href="/news/" class="group inline-flex items-center gap-2 text-sm tracking-wider text-olive font-semibold hover:text-olive-dark transition-colors">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15m0 0l6.75 6.75M4.5 12l6.75-6.75"/></svg>
          返回新闻列表
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageBanner from '@/components/PageBanner.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import { categories, services } from '@/data/services';
---

<BaseLayout title="服务项目">
  <PageBanner title="服务项目" description="全方位建筑工程服务体系" />

  <section class="py-16 lg:py-24 bg-stone-50">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <!-- 分类 -->
      <div class="flex flex-wrap gap-3 mb-12">
        <a
          href="/services/"
          class="px-4 py-1.5 text-xs tracking-wider border border-stone-800 text-stone-800 bg-stone-800 text-white"
        >
          全部
        </a>
        {categories.map(cat => (
          <a
            href={`/services/?category=${cat.slug}`}
            class="px-4 py-1.5 text-xs tracking-wider border border-stone-300 text-stone-500 hover:border-stone-500 hover:text-stone-700 transition-colors"
          >
            {cat.name}
          </a>
        ))}
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        {services.map(service => (
          <ServiceCard
            name={service.name}
            category={service.category}
            description={service.description}
            slug={service.slug}
            icon={service.icon}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageBanner from '@/components/PageBanner.astro';
import { getStaticPaths as getPaths } from '@/data/services';
import type { Service } from '@/data/services';

export function getStaticPaths() {
  return getPaths();
}

const { service } = Astro.props as { service: Service };
---

<BaseLayout title={service.name}>
  <PageBanner title={service.name} description={service.category} />

  <section class="py-16 lg:py-24 bg-white border-b border-stone-200">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <span class="text-[10px] tracking-[0.2em] text-stone-400 uppercase mb-4 block">{service.category}</span>
      <h1 class="text-2xl lg:text-3xl font-bold text-stone-900 tracking-tight mb-8">{service.name}</h1>

      <div class="text-stone-600 leading-relaxed space-y-4 mb-12" set:html={service.detail} />

      <!-- 服务特点 -->
      <div class="border-t border-stone-200 pt-10 mb-12">
        <h2 class="text-lg font-semibold text-stone-800 mb-6">服务特点</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {service.features.map(feature => (
            <div class="flex items-center gap-3 py-2">
              <div class="w-1.5 h-1.5 bg-accent rounded-full shrink-0"></div>
              <span class="text-sm text-stone-600">{feature}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="border border-stone-200 p-10 text-center">
        <h3 class="text-lg font-semibold text-stone-800 mb-2">需要{service.name}？</h3>
        <p class="text-sm text-stone-400 mb-6">欢迎联系我们，获取详细的服务方案和报价</p>
        <a href="/contact/" class="group inline-flex items-center gap-2 px-8 py-3 border border-stone-800 text-stone-800 text-sm tracking-wider font-semibold hover:bg-stone-800 hover:text-white transition-all duration-300">
          立即咨询
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageBanner from '@/components/PageBanner.astro';
import { getStaticPaths as getPaths } from '@/data/services';
import type { Service } from '@/data/services';

export function getStaticPaths() {
  return getPaths();
}

const { service } = Astro.props as { service: Service };
---

<BaseLayout title={service.name}>
  <PageBanner title={service.name} description={service.category} />

  <div class="section-divider"></div>

  <section class="py-14 lg:py-20 bg-stone-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-[10px] tracking-[0.2em] text-olive font-bold uppercase mb-4 block">{service.category}</span>
      <h1 class="text-2xl lg:text-3xl font-bold text-stone-900 tracking-tight mb-8">{service.name}</h1>

      <div class="text-stone-600 text-sm lg:text-base leading-relaxed space-y-4 mb-12" set:html={service.detail} />

      <div class="border-t border-stone-200 pt-8 mb-12">
        <h2 class="text-base font-bold text-stone-800 mb-5">服务特点</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {service.features.map(feature => (
            <div class="flex items-center gap-3 py-1.5">
              <svg class="w-4 h-4 text-olive shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-sm text-stone-600">{feature}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="bg-stone-900 border border-stone-800 p-8 lg:p-10 text-center relative overflow-hidden">
        <div class="absolute inset-0 opacity-[0.03]" style="background: repeating-linear-gradient(-45deg, transparent, transparent 3px, #C4A35A 3px, #C4A35A 4px);"></div>
        <div class="relative z-10">
          <h3 class="text-base font-bold text-stone-100 mb-2">需要{service.name}？</h3>
          <p class="text-xs text-stone-400 mb-6">欢迎联系我们，获取详细的服务方案和报价</p>
          <a href="/contact/" class="group inline-flex items-center gap-2 px-7 py-2.5 bg-olive text-stone-100 text-sm tracking-wider font-bold hover:bg-olive-dark transition-colors">
            立即咨询
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
